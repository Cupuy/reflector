# Servidor
PORT=3000

# WhatsApp Cloud API (Meta) — App Dashboard > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=        # token de acesso (em dev, token temporário de 24h; depois, system user token)
WHATSAPP_PHONE_NUMBER_ID=     # ID do número remetente (não é o número de telefone em si)
WHATSAPP_BUSINESS_ACCOUNT_ID= # WABA ID
WHATSAPP_APP_SECRET=          # App Dashboard > Settings > Basic — usado para validar X-Hub-Signature-256
WHATSAPP_VERIFY_TOKEN=        # string arbitrária sua, repetida na configuração do webhook na Meta
WHATSAPP_API_VERSION=v23.0

# Discord Bot — opcionais; omita o bloco para desabilitar o canal Discord
# Developer Portal: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=        # Bot > Token
DISCORD_APPLICATION_ID=   # General Information > Application ID
DISCORD_PUBLIC_KEY=       # General Information > Public Key (hex, para verificar Interactions)
# Intents necessários (Bot > Privileged Gateway Intents): MESSAGE CONTENT

# Slack App — opcionais; omita o bloco para desabilitar o canal Slack
# App Dashboard: https://api.slack.com/apps
SLACK_BOT_TOKEN=          # OAuth & Permissions > Bot User OAuth Token (xoxb-...)
SLACK_SIGNING_SECRET=     # Basic Information > Signing Secret
# Escopos OAuth necessários: chat:write, channels:read, groups:read, im:read, im:write,
#   mpim:read, reactions:add, channels:history, groups:history, im:history

# Microsoft Teams Bot — opcionais; omita o bloco para desabilitar o canal Teams
# Azure Portal > App registrations > seu app > Overview
# Guia de setup: https://learn.microsoft.com/azure/bot-service/bot-service-quickstart-registration
TEAMS_APP_ID=             # Application (client) ID do Azure App Registration
TEAMS_APP_PASSWORD=       # Client secret criado em Certificates & secrets
TEAMS_TENANT_ID=          # Directory (tenant) ID — omita para bots multi-tenant
# No Teams Admin Center: instale o bot num time e configure o endpoint de mensagem:
#   https://<seu-host>/webhooks/teams
# Permissões de aplicativo (Graph, com consentimento de admin) usadas pelo provisionamento
# e pela descoberta/captura de canais — nenhuma é exigida só para enviar/receber DM:
#   User.Read.All, TeamsAppInstallation.ReadWriteForUser.All, Channel.ReadBasic.All,
#   ChannelMessage.Read.All
# Para envio proativo (openDM), o bot precisa estar instalado no scope pessoal do usuário

# Necessário só para o Teams capturar replies de canal sem @menção (Microsoft Graph change
# notifications, ver docs/learnings.md) — o Graph precisa de uma URL pública para chamar de
# volta, e valida essa URL de forma síncrona ao criar a assinatura (o servidor precisa estar
# acessível, ex.: via ngrok, *antes* de clicar em "ativar captura" no dashboard)
PUBLIC_BASE_URL=          # ex.: https://seu-subdominio.ngrok-free.app (sem barra no final)
