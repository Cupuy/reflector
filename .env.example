# Servidor
PORT=3000

# WhatsApp Cloud API (Meta) — App Dashboard > WhatsApp > API Setup
WHATSAPP_ACCESS_TOKEN=        # token de acesso (em dev, token temporário de 24h; depois, system user token)
WHATSAPP_PHONE_NUMBER_ID=     # ID do número remetente (não é o número de telefone em si)
WHATSAPP_BUSINESS_ACCOUNT_ID= # WABA ID
WHATSAPP_APP_SECRET=          # App Dashboard > Settings > Basic — usado para validar X-Hub-Signature-256
WHATSAPP_VERIFY_TOKEN=        # string arbitrária sua, repetida na configuração do webhook na Meta
WHATSAPP_API_VERSION=v23.0

# Discord Bot — opcionais; omita o bloco para desabilitar o canal Discord
# Developer Portal: https://discord.com/developers/applications
DISCORD_BOT_TOKEN=        # Bot > Token
DISCORD_APPLICATION_ID=   # General Information > Application ID
DISCORD_PUBLIC_KEY=       # General Information > Public Key (hex, para verificar Interactions)
# Intents necessários (Bot > Privileged Gateway Intents): MESSAGE CONTENT
