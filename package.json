{
  "name": "reflector",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Laboratório de integração com canais de comunicação — webhooks e APIs",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "fastify": "^5.3.0",
    "fastify-raw-body": "^5.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
